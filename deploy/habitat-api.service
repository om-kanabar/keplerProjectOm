[Unit]
Description=Habitat API server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HABITAT_API_HOST=0.0.0.0
Environment=HABITAT_API_PORT=8787
WorkingDirectory=%h/habitat-cli
ExecStart=/bin/bash -lc 'bun run server'
Restart=always
RestartSec=5
TimeoutStopSec=10
NoNewPrivileges=true

[Install]
WantedBy=default.target
